{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "build",
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "sourceMap": false
  },
  "include": [
    "server.ts"
  ]
}